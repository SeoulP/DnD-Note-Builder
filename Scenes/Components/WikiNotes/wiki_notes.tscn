[gd_scene format=3]

[ext_resource type="Script" path="res://Scenes/Components/WikiNotes/WikiNotes.cs" id="1_wikinotes"]

[node name="WikiNotes" type="VBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 0
script = ExtResource("1_wikinotes")

[node name="NotesInput" type="TextEdit" parent="."]
custom_minimum_size = Vector2(0, 120)
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "DM notes... use [[Name]] to link"
wrap_mode = 1
caret_blink = true

[node name="NotesRenderer" type="RichTextLabel" parent="."]
layout_mode = 2
size_flags_horizontal = 3
bbcode_enabled = true
fit_content = true
scroll_active = false
visible = false

[node name="StubHint" type="Label" parent="."]
layout_mode = 2
text = "[[Name]] links to a note  ·  [[+NoteType]] creates a new one  (NPC, Location, Item, Faction, Quest)"
autowrap_mode = 3
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.5, 0.5, 0.5, 1)
