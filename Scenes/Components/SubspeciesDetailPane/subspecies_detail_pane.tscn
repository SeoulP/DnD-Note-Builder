_notes               = NodePath("Margin/VBox/ContentHBox/Fields/Notes")
_imageCarousel       = NodePath("Margin/VBox/ContentHBox/CarouselColumn/ImageCarousel")

[node name="Margin" type="MarginContainer" parent="."]
