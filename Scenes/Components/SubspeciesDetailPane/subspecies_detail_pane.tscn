[node name="SubspeciesDetailPane" type="ScrollContainer" node_paths=PackedStringArray("_nameInput","_parentRow","_descInput","_notes","_abilitiesContainer","_addAbilityButton","_deleteButton","_imageCarousel")]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")
_nameInput           = NodePath("Margin/VBox/NameRow/NameInput")
_deleteButton        = NodePath("Margin/VBox/NameRow/DeleteButton")
_parentRow           = NodePath("Margin/VBox/ContentHBox/Fields/ParentRow")
_descInput           = NodePath("Margin/VBox/ContentHBox/Fields/DescInput")
